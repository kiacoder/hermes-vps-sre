# =============================================================================
# LLM PROVIDER (Google AI Studio / Gemini)
# =============================================================================
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GOOGLE_API_KEY=your_gemini_api_key_here

# =============================================================================
# TELEGRAM INTEGRATION
# =============================================================================
# Get token from @BotFather on Telegram (https://t.me/BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Comma-separated list of Telegram User IDs allowed to interact with the bot
# Messages from users not in this list will be ignored!
TELEGRAM_ALLOWED_USERS=your_telegram_user_id_here
